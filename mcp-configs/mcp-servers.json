{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "description": "GitHub API — repos, issues, PRs, Actions"
    },
    "aws": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-aws"],
      "env": {
        "AWS_PROFILE": "$AWS_PROFILE",
        "AWS_REGION": "$AWS_REGION"
      },
      "description": "AWS API — EC2, S3, RDS, ECS, Lambda, IAM"
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server-cloudflare"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "$CLOUDFLARE_API_TOKEN"
      },
      "description": "Cloudflare — DNS, CDN, Workers, Pages"
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp-server-vercel"],
      "env": {
        "VERCEL_TOKEN": "$VERCEL_TOKEN"
      },
      "description": "Vercel — Deployments, domains, environment variables"
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "$SUPABASE_ACCESS_TOKEN"
      },
      "description": "Supabase — Database, auth, storage, edge functions"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "Local filesystem access for infrastructure files"
    },
    "docker": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-docker"],
      "description": "Docker — containers, images, volumes, networks"
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-kubernetes"],
      "env": {
        "KUBECONFIG": "$KUBECONFIG"
      },
      "description": "Kubernetes — pods, services, deployments, namespaces"
    }
  }
}
